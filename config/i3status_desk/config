general {
        colors = true
        interval = 5
}

order += "ethernet _first_"
order += "wireless _first_"
order += "tztime local"

wireless _first_ {
        format_up = "W: (%quality at %essid) %ip"
        format_down = "W: down"
}

ethernet _first_ {

}

battery all {
        format = "%status %percentage"
}

tztime local {
        format = "%Y-%m-%d %H:%M"
}